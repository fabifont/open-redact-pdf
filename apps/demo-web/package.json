{
  "name": "open-redact-pdf-demo-web",
  "private": true,
  "version": "0.4.0",
  "type": "module",
  "scripts": {
    "predev": "node ../../scripts/ensure-demo-artifacts.mjs",
    "dev": "vite",
    "prebuild": "node ../../scripts/ensure-demo-artifacts.mjs",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "pretest": "node ../../scripts/ensure-demo-artifacts.mjs",
    "test": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "@fabifont/open-redact-pdf": "workspace:*",
    "pdfjs-dist": "^5.4.394",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "prettier": "^3.5.3",
    "typescript": "^5.9.3",
    "vite": "^7.1.12",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0"
  }
}
