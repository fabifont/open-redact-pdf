{
  "name": "open-redact-pdf",
  "private": true,
  "version": "0.3.0",
  "author": "Fabio Fontana <me@fabifont.dev>",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fabifont/open-redact-pdf.git"
  },
  "bugs": {
    "url": "https://github.com/fabifont/open-redact-pdf/issues"
  },
  "homepage": "https://fabifont.github.io/open-redact-pdf/",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm wasm:build && pnpm -r build",
    "check": "pnpm -r typecheck && cargo check --workspace",
    "lint": "pnpm -r lint && cargo clippy --workspace --all-targets -- -D warnings",
    "test": "cargo test --workspace && pnpm -r test",
    "fmt": "cargo fmt --all && pnpm -r format",
    "wasm:build": "node scripts/build-wasm.mjs"
  }
}
